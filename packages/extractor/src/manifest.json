{
  "manifest_version": 3,
  "name": "Web to Figma",
  "version": "0.1.0",
  "description": "Extract web page DOM and styles into a Figma-ready JSON format.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/index.html"
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  }
}
