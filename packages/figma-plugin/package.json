{
  "name": "@web-to-figma/figma-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Figma plugin that renders extracted web page data into editable Figma layers",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "echo 'no tests configured yet'"
  },
  "dependencies": {
    "@web-to-figma/shared": "workspace:*"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.106.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
